# ============================================================
# MTProxy Manager - Конфигурация
# Скопируйте этот файл в .env и настройте под свои нужды
# cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# Основные настройки Flask
# ------------------------------------------------------------

# Режим работы: development / production
FLASK_CONFIG=production

# Секретный ключ (ОБЯЗАТЕЛЬНО замените на свой!)
# Генерация: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-me-in-production

# Режим отладки (true/false) - в production должен быть false!
FLASK_DEBUG=false

# ------------------------------------------------------------
# Веб-сервер
# ------------------------------------------------------------

# Хост для Flask (127.0.0.1 для локального доступа, 0.0.0.0 для всех интерфейсов)
FLASK_HOST=127.0.0.1

# Порт веб-приложения
FLASK_PORT=5000

# ------------------------------------------------------------
# MTG Proxy настройки
# ------------------------------------------------------------

# Домен или IP сервера (для генерации ссылок на прокси)
SERVER_DOMAIN=your-server.com

# Порт MTG Proxy (рекомендуется 443 для маскировки под HTTPS)
MTG_PORT=443

# Порт для статистики MTG (внутренний)
MTG_STATS_PORT=3129

# Путь к бинарному файлу MTG
MTG_BINARY_PATH=/usr/local/bin/mtg

# Путь к директории конфигурации MTG
MTG_CONFIG_PATH=mtg

# Имя systemd сервиса MTG
MTG_SERVICE_NAME=mtg-proxy

# ------------------------------------------------------------
# База данных
# ------------------------------------------------------------

# Путь к базе данных SQLite
DATABASE_URL=sqlite:///data/mtproxy.db

# ------------------------------------------------------------
# Безопасность
# ------------------------------------------------------------

# Максимум неудачных попыток входа до блокировки
MAX_LOGIN_ATTEMPTS=5

# Время блокировки аккаунта в секундах (15 минут)
LOGIN_BLOCK_TIME=900

# ------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------

# Включить ограничение запросов
RATELIMIT_ENABLED=true

# Хранилище для rate limiter (memory:// для одного процесса)
RATELIMIT_STORAGE_URL=memory://

# Лимит по умолчанию
RATELIMIT_DEFAULT=100 per hour

# ------------------------------------------------------------
# Резервное копирование
# ------------------------------------------------------------

# Максимальное количество хранимых бэкапов
MAX_BACKUPS=10

# Автоматический бэкап (true/false)
AUTO_BACKUP_ENABLED=false

# Интервал автобэкапа: daily / weekly / monthly
AUTO_BACKUP_INTERVAL=daily

# Время автобэкапа (только час, минуты всегда 00)
AUTO_BACKUP_HOUR=3

# ------------------------------------------------------------
# Пути к директориям
# ------------------------------------------------------------

# Директория для скриптов
SCRIPTS_PATH=scripts

# Директория для бэкапов
BACKUPS_PATH=backups

# Директория для данных
DATA_PATH=data

# Директория для логов
LOGS_PATH=logs

# ------------------------------------------------------------
# Логирование
# ------------------------------------------------------------

# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Максимальный размер файла лога (в байтах)
LOG_MAX_SIZE=10485760

# Количество backup файлов логов
LOG_BACKUP_COUNT=10