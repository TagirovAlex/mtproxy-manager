# =========================
# Core
# =========================
FLASK_CONFIG=production
SECRET_KEY=change_me_to_long_random_secret

# Только SQLite
DATABASE_URL=sqlite:////opt/mtproxy-manager/data/mtproxy.db

# =========================
# Session / Auth
# =========================
LOGIN_ATTEMPTS_LIMIT=5
LOGIN_BLOCK_TIME=900

# =========================
# MTG
# =========================
MTG_BINARY_PATH=/usr/local/bin/mtg
MTG_SERVICE_NAME=mtg-proxy
MTG_STATS_PORT=3129

# Управление systemd из приложения (через sudo -n systemctl ...)
SYSTEMCTL_USE_SUDO=true

# =========================
# Scripts security
# =========================
PYTHON_BINARY_PATH=python3
SCRIPT_TIMEOUT_SECONDS=300

# Разрешенные скрипты через запятую (только basename):
# SCRIPT_ALLOWLIST=healthcheck.sh,rotate_logs.sh,collect_metrics.py
SCRIPT_ALLOWLIST=

# =========================
# Server/UI settings
# =========================
SERVER_DOMAIN=example.com
MAX_KEYS_PER_USER=5

# =========================
# Installer security
# =========================
# Рекомендуется задавать при запуске install.sh / mtg_install.sh:
# MTG_SHA256=<sha256_of_mtg_tarball>
MTG_SHA256=